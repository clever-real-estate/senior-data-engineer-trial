# Copy this to .env and adjust as needed
# docker-compose will pick up .env automatically

# Airflow
AIRFLOW_UID=50000

# Mock Databricks settings (no real cluster needed)
DATABRICKS_HOST=http://mock-databricks:9999
DATABRICKS_TOKEN=mock-token-for-local-dev

# Pipeline paths (inside the container)
RAW_DATA_PATH=/opt/airflow/data/raw
OUTPUT_DATA_PATH=/opt/airflow/data/output
